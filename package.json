{
  "name": "clui",
  "version": "0.1.0",
  "description": "Clui CC — Command Line User Interface for Claude Code",
  "license": "MIT",
  "author": "Luis Miguel <LuisMIguelFurlanettoSousa@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/LuisMIguelFurlanettoSousa/clui-cc-linux.git"
  },
  "bugs": {
    "url": "https://github.com/LuisMIguelFurlanettoSousa/clui-cc-linux/issues"
  },
  "homepage": "https://github.com/LuisMIguelFurlanettoSousa/clui-cc-linux#readme",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start:linux": "bash start.sh",
    "dist": "electron-vite build && electron-builder --linux deb",
    "dist:appimage": "electron-vite build && electron-builder --linux AppImage",
    "doctor": "bash scripts/doctor.sh",
    "postinstall": "electron-builder install-app-deps && bash scripts/patch-dev-icon.sh"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "framer-motion": "^12.35.1",
    "node-pty": "^1.1.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.clui.app",
    "productName": "Clui CC",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "resources/icon.icns"
    },
    "linux": {
      "icon": "resources/icons",
      "target": ["AppImage", "deb"],
      "category": "Development",
      "desktop": {
        "Name": "Clui CC",
        "Comment": "Desktop overlay for Claude Code CLI",
        "Categories": "Development;Utility;"
      }
    },
    "deb": {
      "depends": ["libnotify4", "libsecret-1-0", "libgtk-3-0"],
      "afterInstall": "build/after-install.sh"
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "postcss": "^8.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
